<Window x:Class="DbQueryExplorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DbQueryExplorer.ViewModels"
        xmlns:models="clr-namespace:DbQueryExplorer.Models"
        xmlns:conv="clr-namespace:DbQueryExplorer.Converters"
        Title="DB Query Explorer" Height="860" Width="1320"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolNegationConverter      x:Key="BoolNeg"/>
        <conv:BoolToVisibilityConverter   x:Key="BoolVis"/>
        <conv:BoolNegToVisibilityConverter x:Key="BoolNegVis"/>
        <conv:CountToVisibilityConverter  x:Key="CountVis"/>
        <conv:CountToVisibilityConverter  x:Key="CountVisInv" Invert="True"/>
        <BooleanToVisibilityConverter     x:Key="StdBoolVis"/>

        <!-- Primary button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4472C4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E57A8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#C0392B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A93226"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#7F8C8D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#626567"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card panel style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.12" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input style -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════ TITLE BAR ══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#4472C4" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🗄" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="DB Query Explorer" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding ConnectionStatus}" Foreground="#D6E4FF"
                           HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>

        <!-- ══════════════════ CONNECTION PANEL ══════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="12,10,12,4">
            <StackPanel>

                <!-- ── PROFILE MODE ──────────────────────────────────────────── -->
                <WrapPanel Orientation="Horizontal"
                           Visibility="{Binding IsManualMode, Converter={StaticResource BoolNegVis}}">

                    <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="Bağlantı:" Style="{StaticResource Label}" Margin="0,0,6,0"/>
                        <ComboBox Width="280"
                                  ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource Combo}"
                                  IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <Button Content="  Bağlan  " Command="{Binding ConnectCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>

                    <Button Content="  Bağlantıyı Kes  " Command="{Binding DisconnectCommand}"
                            Style="{StaticResource DangerButton}" Margin="0,0,14,0"
                            IsEnabled="{Binding IsConnected}"/>

                    <TextBlock VerticalAlignment="Center" Foreground="#888" FontSize="12">
                        <Hyperlink Command="{Binding ToggleManualModeCommand}" Foreground="#4472C4">
                            <Run Text="Manuel bağlantı →"/>
                        </Hyperlink>
                    </TextBlock>
                </WrapPanel>

                <!-- ── MANUAL MODE ────────────────────────────────────────────── -->
                <WrapPanel Orientation="Horizontal"
                           Visibility="{Binding IsManualMode, Converter={StaticResource BoolVis}}">

                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="DB:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <ComboBox Width="90" ItemsSource="{Binding DbTypes}"
                                  SelectedItem="{Binding SelectedDbType}"
                                  Style="{StaticResource Combo}"
                                  IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Sunucu:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <TextBox Width="155" Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Input}"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Port:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <TextBox Width="52" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Input}"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Veritabanı:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <TextBox Width="130" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Input}"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Kullanıcı:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <TextBox Width="115" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Input}"
                                 IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Parola:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <PasswordBox x:Name="PasswordInput" Width="115"
                                     PasswordChanged="PasswordInput_PasswordChanged"
                                     Padding="6,4" BorderBrush="#BDC3C7" BorderThickness="1"
                                     IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>
                    </StackPanel>

                    <Button Content="  Bağlan  " Command="{Binding ConnectCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,6,4"
                            IsEnabled="{Binding IsConnected, Converter={StaticResource BoolNeg}}"/>

                    <Button Content="  Bağlantıyı Kes  " Command="{Binding DisconnectCommand}"
                            Style="{StaticResource DangerButton}" Margin="0,0,14,4"
                            IsEnabled="{Binding IsConnected}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,6,4" VerticalAlignment="Center"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="Profil adı:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                        <TextBox Width="140" Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource Input}" ToolTip="Bağlantıyı profil olarak kaydet"/>
                        <Button Content="💾  Kaydet" Command="{Binding SaveProfileCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="5,0,0,0"
                                ToolTip="Bu bağlantıyı connections.json dosyasına ekle"/>
                    </StackPanel>

                    <TextBlock VerticalAlignment="Center" Margin="0,0,0,4"
                               Visibility="{Binding HasProfiles, Converter={StaticResource BoolVis}}">
                        <Hyperlink Command="{Binding ToggleManualModeCommand}" Foreground="#4472C4">
                            <Run Text="← Profil listesine dön"/>
                        </Hyperlink>
                    </TextBlock>
                </WrapPanel>

            </StackPanel>
        </Border>

        <!-- ══════════════════ MAIN CONTENT ══════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="12,4,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Tables ───────────────────────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Tablolar" Style="{StaticResource SectionHeader}"/>
                    <TextBlock DockPanel.Dock="Top" Foreground="#888" FontSize="11" Margin="0,0,0,6"
                               Text="{Binding Tables.Count, StringFormat={}{0} tablo}"/>
                    <ListBox ItemsSource="{Binding Tables}"
                             SelectedItem="{Binding SelectedTable}"
                             BorderThickness="1" BorderBrush="#E0E0E0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EBF0FA"/>
                                        <Setter Property="Foreground" Value="#4472C4"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- ── SPLITTER ────────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ── RIGHT: Query + Results ────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="240"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="3*" MinHeight="150"/>
                </Grid.RowDefinitions>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              Background="#D0D8EC" Cursor="SizeNS"/>

                <!-- ── MODE TABS ──────────────────────────────────────────── -->
                <TabControl Grid.Row="0" Margin="0,0,0,6" Background="White"
                            BorderBrush="#D0D8EC" BorderThickness="1">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="16,7"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Background" Value="#EEF0F5"/>
                            <Setter Property="Foreground" Value="#555"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#4472C4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <!-- ── Tab 1: Tablo Modu ──────────────────────────────── -->
                    <TabItem Header="📋  Tablo Modu">
                        <DockPanel LastChildFill="True" Margin="0,6,0,0">

                            <!-- ═══ ACTION BAR ════════════════════════════════════════════ -->
                            <Border DockPanel.Dock="Top" Background="White"
                                    BorderBrush="#D0D8EC" BorderThickness="1" CornerRadius="6"
                                    Padding="10,8" Margin="0,0,0,6">
                                <DockPanel LastChildFill="False">
                                    <Button DockPanel.Dock="Right" Content="▶  Sorguyu Çalıştır"
                                            Command="{Binding RunQueryCommand}"
                                            Style="{StaticResource SuccessButton}"
                                            IsEnabled="{Binding IsConnected}"/>

                                    <!-- Row limit picker -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="İlk" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                                        <ComboBox ItemsSource="{Binding RowLimitOptions}"
                                                  SelectedItem="{Binding RowLimit}"
                                                  Width="75" Style="{StaticResource Combo}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding}" Value="0">
                                                                        <Setter Property="Text" Value="Tümü"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <TextBlock Text="kayıt" Style="{StaticResource Label}" Margin="5,0,0,0"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Tablo:" Style="{StaticResource Label}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding SelectedTable, FallbackValue='—'}"
                                                   FontWeight="Bold" Foreground="#2C3E50" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- ═══ SCROLLABLE CONTENT ════════════════════════════════════ -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>

                                    <!-- ─── 1. SÜTUNLAR ──────────────────────────────────── -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,6"
                                            Visibility="{Binding HasColumns, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Sütunlar" Style="{StaticResource SectionHeader}" Margin="0"/>
                                                    <Border Background="#EBF0FA" CornerRadius="10" Padding="8,2" Margin="8,0,0,8">
                                                        <TextBlock Text="{Binding SelectableColumns.Count, StringFormat={}{0} alan}"
                                                                   Foreground="#4472C4" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Content="Tümünü Seç"    Command="{Binding SelectAllColumnsCommand}"
                                                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"/>
                                                    <Button Content="Tümünü Kaldır" Command="{Binding DeselectAllColumnsCommand}"
                                                            Style="{StaticResource SecondaryButton}"/>
                                                </StackPanel>
                                            </Grid>
                                            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding SelectableColumns}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type models:SelectableColumn}">
                                                            <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                          Margin="0,3,6,3" Cursor="Hand" FocusVisualStyle="{x:Null}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="chip" CornerRadius="14" BorderThickness="1.5"
                                                                                Padding="10,6" Background="White" BorderBrush="#C8D4E8">
                                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                                <TextBlock x:Name="colName" Text="{Binding Name}"
                                                                                           FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                                                <Border x:Name="typeBadge" Margin="5,0,0,0" Padding="4,1"
                                                                                        CornerRadius="8" Background="#EEF2FA" VerticalAlignment="Center">
                                                                                    <TextBlock x:Name="colType" Text="{Binding DataType}"
                                                                                               FontSize="9" FontWeight="SemiBold" Foreground="#8096B8"/>
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="chip"      Property="Background"  Value="#4472C4"/>
                                                                                <Setter TargetName="chip"      Property="BorderBrush" Value="#4472C4"/>
                                                                                <Setter TargetName="colName"   Property="Foreground"  Value="White"/>
                                                                                <Setter TargetName="typeBadge" Property="Background" Value="#2E5AA8"/>
                                                                                <Setter TargetName="colType"   Property="Foreground"  Value="#C8D8F4"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="chip" Property="Opacity" Value="0.85"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── 2. SÜTUN DÖNÜŞÜMLERİ ─────────────────────────── -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Sütun Dönüşümleri" Style="{StaticResource SectionHeader}" Margin="0"/>
                                                    <Border Background="#FFF3E0" CornerRadius="4" Padding="6,2" Margin="8,0,0,6">
                                                        <TextBlock Text="örn: Gender → M=Erkek, F=Kadın"
                                                                   Foreground="#E65100" FontSize="10"/>
                                                    </Border>
                                                </StackPanel>
                                                <Button Content="+ Dönüşüm Ekle" Command="{Binding AddValueMapperCommand}"
                                                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                                                        IsEnabled="{Binding IsConnected}"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding ValueMappers}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:ValueMapper}">
                                                        <Border Background="#FAFCFF" BorderBrush="#C8D8F0" BorderThickness="1"
                                                                CornerRadius="6" Margin="0,0,0,8" Padding="10">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                    <ComboBox Grid.Column="1"
                                                                              ItemsSource="{Binding AvailableColumns}"
                                                                              Text="{Binding SourceColumn, UpdateSourceTrigger=PropertyChanged}"
                                                                              Style="{StaticResource Combo}" IsEditable="True"
                                                                              ToolTip="Dönüştürülecek sütun (örn: Gender)"/>
                                                                    <Button Grid.Column="2" Content="Kaldır" Height="26" Padding="10,0" Margin="8,0,0,0"
                                                                            Background="#FFEEEE" BorderThickness="0" Cursor="Hand"
                                                                            Foreground="#C0392B" FontSize="11" VerticalAlignment="Center"
                                                                            CommandParameter="{Binding}"
                                                                            Command="{Binding DataContext.RemoveValueMapperCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                </Grid>

                                                                <Grid Margin="4,0,0,3">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="30"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="28"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="Veritabanındaki değer"
                                                                               FontSize="10" Foreground="#777" FontWeight="SemiBold"/>
                                                                    <TextBlock Grid.Column="2" Text="Gösterilecek değer"
                                                                               FontSize="10" Foreground="#777" FontWeight="SemiBold"/>
                                                                </Grid>

                                                                <ItemsControl ItemsSource="{Binding Mappings}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type models:ValueMapping}">
                                                                            <Grid Margin="0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="30"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="28"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBox Grid.Column="0"
                                                                                         Text="{Binding SourceValue, UpdateSourceTrigger=PropertyChanged}"
                                                                                         Style="{StaticResource Input}" ToolTip="Veritabanındaki değer (örn: M)"/>
                                                                                <TextBlock Grid.Column="1" Text="→" FontSize="14" FontWeight="Bold"
                                                                                           Foreground="#4472C4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                <TextBox Grid.Column="2"
                                                                                         Text="{Binding DisplayValue, UpdateSourceTrigger=PropertyChanged}"
                                                                                         Style="{StaticResource Input}" ToolTip="Gösterilecek değer (örn: Erkek)"/>
                                                                                <Button Grid.Column="3" Content="✕" Width="24" Height="24" Margin="4,0,0,0"
                                                                                        Background="#FFEEEE" BorderThickness="0" Cursor="Hand"
                                                                                        Foreground="#C0392B" FontWeight="Bold"
                                                                                        CommandParameter="{Binding}"
                                                                                        Command="{Binding DataContext.RemoveValueMappingCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <Grid Margin="0,6,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="140"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button Grid.Column="0" Content="+ Satır Ekle" Height="24" Padding="10,0"
                                                                            FontSize="11" Background="#EBF0FA" BorderThickness="0"
                                                                            Foreground="#4472C4" Cursor="Hand" FontWeight="SemiBold"
                                                                            CommandParameter="{Binding}"
                                                                            Command="{Binding DataContext.AddValueMappingCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                                    <TextBlock Grid.Column="2" Text="Diğerleri (varsayılan):"
                                                                               Style="{StaticResource Label}" Margin="12,0,6,0"/>
                                                                    <TextBox Grid.Column="3"
                                                                             Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                                             Style="{StaticResource Input}"
                                                                             ToolTip="Eşleşmeyen değerler için (boş bırakırsan NULL olur)"/>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Foreground="#AAAAAA" FontSize="12" Margin="0,2,0,0"
                                                       Visibility="{Binding ValueMappers.Count, Converter={StaticResource CountVisInv}}">
                                                Dönüşüm yok. <Hyperlink Command="{Binding AddValueMapperCommand}"
                                                    IsEnabled="{Binding IsConnected}">+ Dönüşüm Ekle</Hyperlink>
                                                ile değer eşleştirmesi yapın.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── 3. HAZIR SEÇENEKLER ───────────────────────────── -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,6">
                                        <StackPanel>
                                            <TextBlock Text="Hazır Seçenekler" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>

                                            <Border Background="#F0F4FB" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox IsChecked="{Binding OnlyRegisteredCustomers}" VerticalAlignment="Center"
                                                              Margin="0,0,10,0"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Sadece Registered Müşteriler"
                                                                   FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                        <TextBlock Text="Üye olmayan / misafir müşterileri dışarıda bırakır."
                                                                   FontSize="10" Foreground="#888" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#F0F4FB" CornerRadius="6" Padding="12,10">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox IsChecked="{Binding IncludeAddressInfo}" VerticalAlignment="Center"
                                                              Margin="0,0,10,0"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="Vergi No &amp; Vergi Dairesi Bilgileri"
                                                                   FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                        <TextBlock Text="Fatura ve teslimat adreslerinden vergi no/vergi dairesi sütunlarını ekler."
                                                                   FontSize="10" Foreground="#888" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── 4. FİLTRELER ─────────────────────────────────── -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,6">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Filtreler" Style="{StaticResource SectionHeader}" Margin="0"/>
                                                    <TextBlock Text="{Binding SelectedTable, StringFormat=' — {0}'}"
                                                               Foreground="#4472C4" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Content="+ Filtre Ekle" Command="{Binding AddFilterCommand}"
                                                            Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
                                                    <Button Content="Filtreleri Sil" Command="{Binding ClearFiltersCommand}"
                                                            Style="{StaticResource SecondaryButton}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,0,0,4"
                                                  Visibility="{Binding Filters.Count, Converter={StaticResource CountVis}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="Sütun"    FontWeight="SemiBold" FontSize="11" Foreground="#888"/>
                                                <TextBlock Grid.Column="2" Text="Operatör" FontWeight="SemiBold" FontSize="11" Foreground="#888"/>
                                                <TextBlock Grid.Column="3" Text="Değer"    FontWeight="SemiBold" FontSize="11" Foreground="#888" Margin="8,0,0,0"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Filters}" MaxHeight="200">
                                                <ItemsControl.Template>
                                                    <ControlTemplate TargetType="ItemsControl">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                            <ItemsPresenter/>
                                                        </ScrollViewer>
                                                    </ControlTemplate>
                                                </ItemsControl.Template>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:FilterRow}">
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="28"/>
                                                                <ColumnDefinition Width="180"/>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="30"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                                                            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableColumns}"
                                                                      SelectedItem="{Binding ColumnName}" Style="{StaticResource Combo}"/>
                                                            <ComboBox Grid.Column="2" Margin="6,0,0,0"
                                                                      ItemsSource="{Binding Source={x:Static models:FilterRow.Operators}}"
                                                                      SelectedItem="{Binding SelectedOperator}"
                                                                      Style="{StaticResource Combo}"/>
                                                            <TextBox Grid.Column="3" Margin="6,0,0,0"
                                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{StaticResource Input}"
                                                                     IsEnabled="{Binding ValueInputVisible}"
                                                                     ToolTip="IN için virgülle ayırın: 1,2,3"/>
                                                            <Button Grid.Column="4" Content="✕" Width="24" Height="24" Margin="4,0,0,0"
                                                                    Background="#FFEEEE" BorderThickness="0" Cursor="Hand"
                                                                    Foreground="#C0392B" FontWeight="Bold"
                                                                    CommandParameter="{Binding}"
                                                                    Command="{Binding DataContext.RemoveFilterCommand,
                                                                              RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Foreground="#AAAAAA" FontSize="12" Margin="0,6,0,0"
                                                       Visibility="{Binding Filters.Count, Converter={StaticResource CountVisInv}}">
                                                Filtre yok — sorgu tüm kayıtları getirir.
                                                <Hyperlink Command="{Binding AddFilterCommand}" IsEnabled="{Binding IsConnected}">
                                                    + Filtre Ekle
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>

                    <!-- ── Tab 2: SQL Modu ────────────────────────────────── -->
                    <TabItem Header="📝  SQL Sorgusu">
                        <Border Style="{StaticResource Card}" Margin="0,6,0,0">
                            <DockPanel>
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <TextBlock Text="SQL Sorgusu" Style="{StaticResource SectionHeader}" Margin="0"/>
                                    <Button Content="▶  Çalıştır" Command="{Binding RunCustomQueryCommand}"
                                            Style="{StaticResource SuccessButton}"
                                            HorizontalAlignment="Right"
                                            IsEnabled="{Binding IsConnected}"/>
                                </Grid>
                                <TextBox Text="{Binding CustomSql, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" AcceptsTab="True"
                                         HorizontalScrollBarVisibility="Auto"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Foreground="#1E1E1E" Background="#FAFAFA"
                                         Padding="10" BorderBrush="#BDC3C7" BorderThickness="1"
                                         MinHeight="220"/>
                            </DockPanel>
                        </Border>
                    </TabItem>

                </TabControl>

                <!-- ── RESULTS PANEL ──────────────────────────────────────── -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Sonuçlar" Style="{StaticResource SectionHeader}" Margin="0"/>
                                <Border Background="#EBF0FA" CornerRadius="10" Padding="8,2" Margin="8,0,0,8"
                                        Visibility="{Binding HasResults, Converter={StaticResource BoolVis}}">
                                    <TextBlock Text="{Binding ResultCount, StringFormat={}{0} kayıt}"
                                               Foreground="#4472C4" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <Button Content="📥  Excel'e Aktar" Command="{Binding ExportExcelCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    HorizontalAlignment="Right"
                                    IsEnabled="{Binding HasResults}"/>
                        </Grid>

                        <Grid>
                            <DataGrid ItemsSource="{Binding Results}"
                                  AutoGenerateColumns="True"
                                  AutoGeneratingColumn="DataGrid_AutoGeneratingColumn"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0F0F0"
                                  AlternatingRowBackground="#F8F9FB"
                                  RowBackground="White"
                                  BorderBrush="#E0E0E0" BorderThickness="1"
                                  ColumnHeaderHeight="32"
                                  RowHeight="28"
                                  FontSize="12"
                                  SelectionMode="Extended"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#4472C4"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="BorderBrush" Value="#365A9E"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                            </DataGrid>

                            <!-- Loading overlay -->
                            <Border Background="#EEF3FF" CornerRadius="8"
                                    Visibility="{Binding IsBusy, Converter={StaticResource StdBoolVis}}"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Padding="36,24" Panel.ZIndex="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="⏳" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Sorgu çalıştırılıyor..."
                                               FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Sonuçlar birazdan aşağıda gözükecek."
                                               FontSize="11" Foreground="#666"
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <ProgressBar IsIndeterminate="True" Height="4" Width="200"
                                                 Foreground="#4472C4" Margin="0,14,0,0" BorderThickness="0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════ STATUS BAR ════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="12,4">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#BDC3C7" FontSize="12"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <ProgressBar Width="120" Height="4" HorizontalAlignment="Right" VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource StdBoolVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
